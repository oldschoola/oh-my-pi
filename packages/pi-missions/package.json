{
	"type": "module",
	"name": "@oh-my-pi/pi-missions",
	"version": "0.3.0",
	"description": "Orchestrated multi-phase development missions for pi — architect, implement, test, audit, verify. Includes MissionControl engine (ported from taskplane) and web dashboard.",
	"homepage": "https://github.com/can1357/oh-my-pi",
	"author": "itisbryan",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/can1357/oh-my-pi.git",
		"directory": "packages/pi-missions"
	},
	"bugs": {
		"url": "https://github.com/can1357/oh-my-pi/issues"
	},
	"keywords": [
		"mission",
		"missioncontrol",
		"orchestration",
		"agent",
		"extension",
		"dashboard"
	],
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"build": "bun run build.ts",
		"dev": "bun run src/server.ts",
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit && tsgo -p tsconfig.client.json --noEmit",
		"lint": "biome lint .",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write .",
		"test": "bun test"
	},
	"dependencies": {
		"@oh-my-pi/pi-utils": "catalog:",
		"@tailwindcss/node": "catalog:",
		"@xterm/addon-clipboard": "catalog:",
		"@xterm/addon-fit": "catalog:",
		"@xterm/addon-web-links": "catalog:",
		"@xterm/xterm": "catalog:",
		"date-fns": "catalog:",
		"jiti": "^2.6.1",
		"lucide-react": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"yaml": "^2.4.0"
	},
	"devDependencies": {
		"@types/bun": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"postcss": "catalog:",
		"tailwindcss": "catalog:"
	},
	"peerDependencies": {
		"@oh-my-pi/pi-coding-agent": "^13",
		"@oh-my-pi/pi-tui": "^13",
		"@sinclair/typebox": "*"
	},
	"peerDependenciesMeta": {
		"@oh-my-pi/pi-coding-agent": {
			"optional": true
		},
		"@oh-my-pi/pi-tui": {
			"optional": true
		},
		"@sinclair/typebox": {
			"optional": true
		}
	},
	"engines": {
		"bun": ">=1.3.7"
	},
	"omp": {
		"extensions": [
			"./src/index.ts"
		],
		"prompts": [
			"./prompts"
		],
		"skills": [
			"./skills"
		]
	},
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./server": {
			"types": "./src/server.ts",
			"import": "./src/server.ts"
		},
		"./telemetry": {
			"types": "./src/telemetry/index.ts",
			"import": "./src/telemetry/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		}
	},
	"files": [
		"src",
		"prompts",
		"skills",
		"templates",
		"build.ts",
		"tailwind.config.js"
	]
}
